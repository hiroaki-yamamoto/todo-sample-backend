# GraphQL schema example
#
# https://gqlgen.com/getting-started/

type Status {
  wipAt: String,
  completedAt: String,
}

type Todo {
  # The ID should be an UUIDv7 string to identify
  # the creation time of the todo item.
  id: ID!
  status: Status!
  text: String!
  user: User!
}

type User {
  id: ID!
  name: String!
}

type Query {
  todos: [Todo!]
  filterBy(wipRange: [String], completedRange: [String]): [Todo!]
}

input NewTodo {
  text: String!
  userId: String!
}
input UpdateTodo {
  id: ID!
  text: String!
  wipAt: String
  completedAt: String
}

type Mutation {
  createTodo(input: NewTodo!): Todo!
  updateTodo(input: UpdateTodo!): Todo!
}
